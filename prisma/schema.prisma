generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  BOOKED
  SUPPRESSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ContactChannelType {
  SMS
  VOICE
}

enum WorkflowType {
  NEW_LEAD_FOLLOW_UP
  ACTIVE_CONVERSATION
  BOOKING
  NO_SHOW_RECOVERY
  RECALL
  REACTIVATION
  REVIEW_REQUEST
}

enum WorkflowStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  RESCHEDULED
  CANCELED
  NO_SHOW
  COMPLETED
}

enum AppointmentExternalSyncStatus {
  PENDING
  SYNCED
  FAILED
  SKIPPED
}

enum ProspectStatus {
  NEW
  NO_ANSWER
  VM_LEFT
  GATEKEEPER
  NOT_INTERESTED
  BOOKED_DEMO
  CLOSED
  DEAD
}

enum ProspectDedupKeyType {
  CLINIC
  PHONE
  WEBSITE
}

enum CrmProvider {
  NONE
  HUBSPOT
  PIPEDRIVE
  GOHIGHLEVEL
  SALESFORCE
  BOULEVARD
  VAGARO
}

enum CrmSyncStatus {
  SUCCESS
  FAILED
  SKIPPED
}

model Company {
  id                      String                   @id @default(cuid())
  name                    String
  notificationEmail       String?
  notificationPhone       String?
  website                 String?
  primaryContactName      String?
  primaryContactEmail     String?
  primaryContactPhone     String?
  retainerCents           Int?
  downPaymentCents        Int?
  telnyxInboundNumber     String?                  @unique
  telnyxAssistantId       String?                  @unique
  crmProvider             CrmProvider              @default(NONE)
  crmCredentialsEncrypted String?
  crmFieldMapping         Json?
  telnyxInboundNumbers    CompanyTelnyxNumber[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  contacts                Contact[]
  contactIdentities       ContactChannelIdentity[]
  leads                   Lead[]
  conversations           Conversation[]
  messages                Message[]
  appointments            Appointment[]
  workflowRuns            WorkflowRun[]
  events                  EventLog[]
  keys                    IdempotencyKey[]
  crmSyncLogs             CrmSyncLog[]
}

model Contact {
  id                String                   @id @default(cuid())
  companyId         String
  name              String?
  phone             String
  email             String?
  createdAt         DateTime                 @default(now())
  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads             Lead[]
  conversations     Conversation[]
  appointments      Appointment[]
  channelIdentities ContactChannelIdentity[]
  workflowRuns      WorkflowRun[]

  @@unique([companyId, phone])
}

model CompanyTelnyxNumber {
  id        String   @id @default(cuid())
  companyId String
  number    String   @unique
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Lead {
  id                String        @id @default(cuid())
  companyId         String
  contactId         String
  status            LeadStatus    @default(NEW)
  source            String?
  sourceExternalId  String?
  lastContactedAt   DateTime?
  lastRepliedAt     DateTime?
  suppressedAt      DateTime?
  suppressionReason String?
  createdAt         DateTime      @default(now())
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact           Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  workflowRuns      WorkflowRun[]
}

model Conversation {
  id           String        @id @default(cuid())
  companyId    String
  contactId    String
  createdAt    DateTime      @default(now())
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages     Message[]
  workflowRuns WorkflowRun[]

  @@unique([companyId, contactId])
}

model Message {
  id             String           @id @default(cuid())
  companyId      String
  conversationId String
  direction      MessageDirection
  content        String
  externalId     String?
  createdAt      DateTime         @default(now())
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                       String                        @id @default(cuid())
  companyId                String
  contactId                String
  startTime                DateTime
  status                   AppointmentStatus             @default(BOOKED)
  purpose                  String?
  meetingUrl               String?
  hostEmail                String?
  attendeeEmails           String[]                      @default([])
  displayCompanyName       String?
  sourceProspectId         String?
  notes                    String?
  callExternalId           String?
  callRecordingUrl         String?
  callTranscriptUrl        String?
  callTranscriptText       String?
  externalCalendarProvider String?
  externalCalendarEventId  String?
  externalSyncStatus       AppointmentExternalSyncStatus @default(PENDING)
  externalSyncError        String?
  externalSyncedAt         DateTime?
  externalSyncAttempts     Int                           @default(0)
  confirmedAt              DateTime?
  canceledAt               DateTime?
  noShowAt                 DateTime?
  completedAt              DateTime?
  createdAt                DateTime                      @default(now())
  company                  Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact                  Contact                       @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model EventLog {
  id        String   @id @default(cuid())
  companyId String
  eventType String
  payload   Json
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  companyId String
  key       String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
}

model CrmSyncLog {
  id         String        @id @default(cuid())
  companyId  String
  leadId     String?
  contactId  String?
  provider   CrmProvider
  status     CrmSyncStatus
  externalId String?
  attempt    Int           @default(1)
  payload    Json
  response   Json?
  error      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([status, createdAt])
  @@index([leadId])
}

model ContactChannelIdentity {
  id          String             @id @default(cuid())
  companyId   String
  contactId   String
  channelType ContactChannelType
  sourceId    String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact     Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([companyId, channelType, sourceId])
  @@index([contactId, channelType])
}

model WorkflowRun {
  id             String         @id @default(cuid())
  companyId      String
  contactId      String
  conversationId String?
  leadId         String?
  workflowType   WorkflowType
  status         WorkflowStatus @default(ACTIVE)
  priority       Int
  nextRunAt      DateTime?
  startedAt      DateTime       @default(now())
  pausedAt       DateTime?
  completedAt    DateTime?
  canceledAt     DateTime?
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  payload        Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([companyId, contactId, status])
  @@index([companyId, contactId, workflowType, status])
  @@index([companyId, nextRunAt])
}

model Prospect {
  id              String               @id @default(cuid())
  companyId       String               @default("fixyourleads")
  name            String
  phone           String?
  city            String?
  website         String?
  ownerName       String?
  status          ProspectStatus       @default(NEW)
  lastCallAt      DateTime?
  lastCallOutcome String?
  nextActionAt    DateTime?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  callLogs        CallLog[]
  dedupeEntries   ProspectDedupEntry[]

  @@index([status])
  @@index([nextActionAt])
  @@index([companyId])
}

model ProspectDedupEntry {
  id         String               @id @default(cuid())
  companyId  String
  keyType    ProspectDedupKeyType
  keyValue   String
  prospectId String
  createdAt  DateTime             @default(now())
  prospect   Prospect             @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([companyId, keyType, keyValue])
  @@index([prospectId])
  @@index([companyId, keyType])
}

model CallLog {
  id              String   @id @default(cuid())
  prospectId      String
  outcome         String
  durationSeconds Int?
  notes           String?
  createdAt       DateTime @default(now())
  prospect        Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId, createdAt])
}

model UnroutedTelnyxEvent {
  id           String   @id @default(cuid())
  eventType    String
  reason       String
  eventId      String?
  messageId    String?
  inboundNumber String?
  fromNumber   String?
  payload      Json
  createdAt    DateTime @default(now())
  handledAt    DateTime?

  @@index([createdAt])
  @@index([reason, createdAt])
  @@index([eventType, createdAt])
}
