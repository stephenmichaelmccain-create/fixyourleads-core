generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  BOOKED
  SUPPRESSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ProspectStatus {
  NEW
  NO_ANSWER
  VM_LEFT
  GATEKEEPER
  BOOKED_DEMO
  CLOSED
  DEAD
}

model Company {
  id                String         @id @default(cuid())
  name              String
  notificationEmail String?
  telnyxInboundNumber String?      @unique
  telnyxInboundNumbers CompanyTelnyxNumber[]
  createdAt         DateTime       @default(now())
  contacts          Contact[]
  leads             Lead[]
  conversations     Conversation[]
  messages          Message[]
  appointments      Appointment[]
  events            EventLog[]
  keys              IdempotencyKey[]
}

model Contact {
  id            String         @id @default(cuid())
  companyId     String
  name          String?
  phone         String
  createdAt     DateTime       @default(now())
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads         Lead[]
  conversations Conversation[]
  appointments  Appointment[]

  @@unique([companyId, phone])
}

model CompanyTelnyxNumber {
  id        String   @id @default(cuid())
  companyId String
  number    String   @unique
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Lead {
  id                String     @id @default(cuid())
  companyId         String
  contactId         String
  status            LeadStatus @default(NEW)
  source            String?
  sourceExternalId  String?
  lastContactedAt   DateTime?
  lastRepliedAt     DateTime?
  suppressedAt      DateTime?
  suppressionReason String?
  createdAt         DateTime   @default(now())
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact           Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Conversation {
  id         String      @id @default(cuid())
  companyId  String
  contactId  String
  createdAt  DateTime    @default(now())
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([companyId, contactId])
}

model Message {
  id             String           @id @default(cuid())
  companyId      String
  conversationId String
  direction      MessageDirection
  content        String
  externalId     String?
  createdAt      DateTime         @default(now())
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Appointment {
  id         String   @id @default(cuid())
  companyId  String
  contactId  String
  startTime  DateTime
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model EventLog {
  id         String   @id @default(cuid())
  companyId  String
  eventType  String
  payload    Json
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model IdempotencyKey {
  id         String   @id @default(cuid())
  companyId  String
  key        String
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
}

model Prospect {
  id              String         @id @default(cuid())
  companyId       String         @default("fixyourleads")
  name            String
  phone           String?
  city            String?
  website         String?
  ownerName       String?
  status          ProspectStatus @default(NEW)
  lastCallAt      DateTime?
  lastCallOutcome String?
  nextActionAt    DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  callLogs        CallLog[]

  @@index([status])
  @@index([nextActionAt])
  @@index([companyId])
}

model CallLog {
  id              String   @id @default(cuid())
  prospectId      String
  outcome         String
  durationSeconds Int?
  notes           String?
  createdAt       DateTime @default(now())
  prospect        Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId, createdAt])
}
