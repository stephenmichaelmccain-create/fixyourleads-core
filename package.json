{
  "name": "fixyourleads-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "test": "vitest run",
    "start": "next start -p ${PORT:-3000} -H 0.0.0.0",
    "check:health": "node -e \"fetch((process.env.APP_BASE_URL || 'http://localhost:3000') + '/api/health').then(async (response) => { console.log(await response.text()); process.exit(response.ok ? 0 : 1); }).catch((error) => { console.error(error); process.exit(1); });\"",
    "env:bootstrap": "node scripts/bootstrap-openclaw-env.mjs",
    "env:openclaw": "node scripts/bootstrap-openclaw-env.mjs",
    "lint": "echo 'lint not configured yet'",
    "db:push": "prisma db push",
    "demo:seed": "tsx scripts/demo-data.ts seed",
    "demo:clear": "tsx scripts/demo-data.ts clear",
    "worker": "tsx workers/index.ts",
    "worker:lead": "tsx workers/process_new_lead.ts",
    "worker:message": "tsx workers/handle_incoming_message.ts",
    "worker:booking": "tsx workers/booking.ts",
    "worker:workflow": "tsx workers/workflows.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@sentry/nextjs": "^10.49.0",
    "bullmq": "^5.49.1",
    "ioredis": "^5.4.1",
    "next": "^15.3.0",
    "nodemailer": "^8.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.2.14",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
